# ── YouTube (required for YouTube URLs) ───────────────────────────────────────
# YouTube Data API v3 key.
# Get one at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Optional: LLM summarization ───────────────────────────────────────────────
# If set, the tool uses an OpenAI-compatible API for richer summarization.
# If not set, heuristic summarization is used automatically — no action needed.
OPENAI_API_KEY=

# Override to use a different OpenAI-compatible base URL (e.g. Ollama, Azure, Groq).
# Default: https://api.openai.com/v1
OPENAI_BASE_URL=

# Override to use a different model.
# Default: gpt-4o-mini
OPENAI_MODEL=
